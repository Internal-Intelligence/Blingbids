# Blingbids.com Environment Variables

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_ESCROW_PROGRAM_ID=Bling1111111111111111111111111111111111111

# Payments
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
ONRAMPER_API_KEY=

# Real-time (Socket.io / WebSocket)
NEXT_PUBLIC_WS_URL=wss://ws.blingbids.com

# Video / Chat (Agora or Twilio)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Storage (listing images, certs, video attestations)
AWS_S3_BUCKET=blingbids-uploads
AWS_REGION=us-east-1

# KYC / Verification
PERSONA_API_KEY=

# xAI Grok (server-side only — never use NEXT_PUBLIC_ prefix)
XAI_API_KEY=
XAI_MODEL=grok-4.3
XAI_BUILD_MODEL=grok-build-0.1
XAI_IMAGE_MODEL=grok-imagine-image-quality